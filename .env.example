# ─── Required ───────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ─── Your Site Info ─────────────────────────────────────
YOUR_SITE=example.com
YOUR_VALUE=quality content about AI and technology

# ─── Free SEO APIs ──────────────────────────────────────
CRAWLY_API_KEY=            # https://getcrawly.com — 100 req/day free
SEOMCP_API_KEY=            # https://seomcp.io — free tier, 67M domains
RANKPARSE_API_KEY=         # https://rankparse.com — 100 free credits
MOZSCAPE_API_KEY=          # https://moz.com — 50 queries/month free

# ─── CAPTCHA Solving (4-tier fallback) ─────────────────
NOPECHA_API_KEY=           # https://nopecha.com — 100 free solves/day
TWO_CAPTCHA_API_KEY=       # https://2captcha.com — paid, most reliable
CAPSOLVER_API_KEY=         # https://capsolver.com — paid, best for Cloudflare
FASTCAPTCHA_API_KEY=       # https://fastcaptcha.org — 100 free OCR credits

# ─── Email (for outreach) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_NAME=Baclink AI
FROM_EMAIL=your_email@gmail.com

# ─── Google Search Console + GA4 ──────────────────────
GSC_API_KEY=               # OAuth2 access token for Google Search Console
GA4_API_KEY=               # OAuth2 access token for Google Analytics 4

# ─── MCP + Dashboard Ports ─────────────────────────────
MCP_HTTP_PORT=3100
DASHBOARD_PORT=3101

# ─── Browser ───────────────────────────────────────────
BROWSER_HEADLESS=true
