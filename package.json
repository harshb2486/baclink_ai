{
  "name": "baclink-ai",
  "version": "4.0.0",
  "description": "AI-powered backlink management agent — MCP server, AEO engine, research, outreach, monitoring",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "baclink": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mcp": "tsx src/index.ts --mcp",
    "dev:http": "tsx src/index.ts --http",
    "dev:dash": "tsx src/index.ts --dashboard",
    "build": "tsc",
    "start": "node dist/index.js",
    "agent": "tsx src/index.ts",
    "mcp": "tsx src/index.ts --mcp",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openai": "^4.86.0",
    "inquirer": "^12.5.0",
    "chalk": "^5.4.0",
    "chalk-animation": "^2.0.3",
    "ora": "^8.1.0",
    "cheerio": "^1.0.0",
    "puppeteer": "^24.6.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-extra-plugin-recaptcha": "^3.6.8",
    "nodemailer": "^6.10.0",
    "axios": "^1.7.9",
    "express": "^5.1.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.7",
    "nanoid": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.17",
    "@types/node-cron": "^3.0.11",
    "@types/inquirer": "^9.0.7",
    "@types/express": "^5.0.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "@types/puppeteer": "^5.4.7"
  }
}
